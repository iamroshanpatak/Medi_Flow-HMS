# MediFlow Backend Environment Variables
# Copy this file to .env and fill in your actual values

# Server Configuration
NODE_ENV=development
PORT=5001
CLIENT_URL=http://localhost:3000

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/mediflow

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_change_in_production_min_32_chars
JWT_EXPIRE=7d

# Frontend URL (for email/SMS links)
FRONTEND_URL=http://localhost:3000

# Email Configuration (REQUIRED for notifications)
# Use Gmail App Password: https://myaccount.google.com/apppasswords
# If not set, emails will be logged to console
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=MediFlow <noreply@mediflow.com>

# SMS Configuration (Twilio - REQUIRED for SMS reminders)
# Get credentials from: https://console.twilio.com
# If not set, SMS will be logged to console
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Redis Configuration (Optional - for caching/sessions)
REDIS_URL=redis://localhost:6379

# Cron Job Configuration (for multi-server deployment)
# Set CRON_INSTANCE to a unique identifier per server
# Set RUN_CRON=true on only ONE server instance in production
CRON_INSTANCE=server-1
RUN_CRON=true

# Socket.IO Configuration
SOCKET_IO_CORS_ORIGIN=http://localhost:3000
